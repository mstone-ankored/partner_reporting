partner_reporting:
  target: dev
  outputs:
    dev:
      type: postgres
      # Use Neon's pooled connection string so idle connections are reclaimed.
      # The easy path: `dbt` uses the unified `DATABASE_URL` Vercel exposes when
      # you provision Neon via the Vercel Neon integration.
      host: "{{ env_var('NEON_HOST') }}"
      user: "{{ env_var('NEON_USER') }}"
      password: "{{ env_var('NEON_PASSWORD') }}"
      port: 5432
      dbname: "{{ env_var('NEON_DATABASE', 'neondb') }}"
      schema: partner_reporting_dev
      sslmode: require
      threads: 4
      keepalives_idle: 0
    prod:
      type: postgres
      host: "{{ env_var('NEON_HOST') }}"
      user: "{{ env_var('NEON_USER') }}"
      password: "{{ env_var('NEON_PASSWORD') }}"
      port: 5432
      dbname: "{{ env_var('NEON_DATABASE', 'neondb') }}"
      schema: partner_reporting
      sslmode: require
      threads: 8
      keepalives_idle: 0
