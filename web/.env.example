# Neon pooled connection string. Vercel's Neon integration exposes this as
# DATABASE_URL automatically when you add Storage → Neon to the project.
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Open signup is gated by this shared secret. Share it with teammates who
# should be able to create accounts; rotate when people leave.
SIGNUP_SECRET=pick-a-strong-string

# Notion (optional, only needed for sync)
NOTION_API_KEY=secret_xxx
