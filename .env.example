# Env vars for local scripts (hubspot_sync.py, notion_sync.py).
# The web app has its own env: web/.env.example.

# Neon (Postgres). Same connection string the web app uses.
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# HubSpot private-app access token. Create under Settings → Integrations →
# Private Apps. Grant these scopes:
#   crm.objects.contacts.read, crm.objects.deals.read,
#   crm.objects.owners.read, crm.schemas.deals.read,
#   sales-email-read, forms, forms-uploaded-files
HUBSPOT_ACCESS_TOKEN=pat-xxx

# Notion integration token (only needed for notion_sync.py).
NOTION_API_KEY=secret_xxx
